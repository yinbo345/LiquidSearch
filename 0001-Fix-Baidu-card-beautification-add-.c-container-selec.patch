Subject: [PATCH] Fix Baidu card beautification: add .c-container selector, fix
 syntax errors, add .gitignore

---
 .gitignore | 19 ++++++++++++++++---
 content.js |  6 +++++-
 popup.html |  2 +-
 3 files changed, 22 insertions(+), 5 deletions(-)

diff --git a/.gitignore b/.gitignore
index b03908e..3545313 100644
--- a/.gitignore
+++ b/.gitignore
@@ -1,4 +1,17 @@
-*.py
-test_*
+# Build artifacts
+*.zip
+*.7z
+*.crx
+
+# Temp files
+release_payload.json
+create_release.py
+fix_all.py
+fix_js.py
+fix_welcome.py
+test_button.html
+
+# OS files
+Thumbs.db
+Desktop.ini
 .DS_Store
-*.log
diff --git a/content.js b/content.js
index 301faf8..7896087 100644
--- a/content.js
+++ b/content.js
@@ -157,6 +157,7 @@
       /* ж¶ІжҖҒзҺ»з’ғеҚЎзүҮпјҡзҷҫеәҰ/Bing/Google/йҖҡз”Ё */
       '#content_left > .result,',
       '#content_left > .result-op,',
+      '#content_left > .c-container,',
       'div.g,',
       'div[data-hveid],',
       '.b_algo,',
@@ -209,6 +210,7 @@
       /* йЎ¶йғЁдё»йўҳиүІй«ҳе…ү */
       '#content_left > .result::before,',
       '#content_left > .result-op::before,',
+      '#content_left > .c-container::before,',
       'div.g::before,',
       '.b_algo::before,',
       '.result::before,',
@@ -238,6 +240,7 @@
       /* еә•йғЁдё»йўҳиүІиҫүе…ү */
       '#content_left > .result::after,',
       '#content_left > .result-op::after,',
+      '#content_left > .c-container::after,',
       'div.g::after,',
       '.b_algo::after,',
       '.result::after,',
@@ -267,6 +270,7 @@
       /* еҚЎзүҮжӮ¬еҒң */
       '#content_left > .result:hover,',
       '#content_left > .result-op:hover,',
+      '#content_left > .c-container:hover,',
       'div.g:hover,',
       'div[data-hveid]:hover,',
       '.b_algo:hover,',
