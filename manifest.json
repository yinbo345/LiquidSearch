{
  "manifest_version": 3,
  "name": "LiquidSearch 液态搜索增强",
  "short_name": "LiquidSearch",
  "version": "1.2",
  "description": "去除搜索引擎广告，液态玻璃风格悬浮卡片，Q弹动画。支持百度、Google、Bing 等 10+ 搜索引擎。",
  "icons": {
    "48": "icon_48.png",
    "128": "icon_128.png"
  },
  "permissions": ["storage", "notifications"],
  "host_permissions": [
    "*://www.baidu.com/*",
    "*://www.google.com/*",
    "*://www.bing.com/*",
    "*://cn.bing.com/*",
    "*://*.duckduckgo.com/*",
    "*://search.yahoo.com/*",
    "*://*.yandex.com/*",
    "*://www.ecosia.org/*",
    "*://search.brave.com/*",
    "*://www.so.com/*",
    "*://www.sogou.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://www.baidu.com/s*",
        "*://www.google.com/search*",
        "*://www.bing.com/search*",
        "*://cn.bing.com/search*",
        "*://www.sogou.com/web*",
        "*://weixin.sogou.com/*",
        "*://www.so.com/s*",
        "*://www.youdao.com/*",
        "*://*.duckduckgo.com/*",
        "*://search.yahoo.com/*",
        "*://*.yandex.com/*",
        "*://www.ecosia.org/*",
        "*://search.brave.com/*"
      ],
      "css": ["style.css"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LiquidSearch 设置"
  }
}
